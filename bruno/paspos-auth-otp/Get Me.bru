meta {
  name: Get Me
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/user
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

settings {
  encodeUrl: true
  followRedirects: true
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("get me returns user id", function() {
    const body = res.getBody();
    expect(body.id).to.be.a("number");
  });
}
