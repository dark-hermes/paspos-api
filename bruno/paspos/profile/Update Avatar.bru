meta {
  name: Update Avatar
  type: http
  seq: 11
}

patch {
  url: {{baseUrl}}/api/me
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:multipart-form {
  avatar: @file(C:\Users\herma\Downloads\confusion_matrix.png)
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("update avatar returns avatar url", function() {
    const body = res.getBody();
    expect(body.status).to.equal("success");
    expect(body.data.avatar_url).to.be.a("string");
  });
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
}
