meta {
  name: Get Brand Detail
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/brands/{{brandId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

settings {
  encodeUrl: true
  followRedirects: true
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("get brand detail returns selected brand", function() {
    const body = res.getBody();
    expect(body.status).to.equal("success");
    expect(body.data.id).to.equal(Number(bru.getEnvVar("brandId")));
  });
}
