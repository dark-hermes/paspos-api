meta {
  name: Update Brand
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/brands/{{brandId}}
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  name: {{brandNameUpdated}}
  ~logo: 
}

settings {
  encodeUrl: true
  followRedirects: true
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("update brand returns success", function() {
    const body = res.getBody();
    expect(body.status).to.equal("success");
  });
}
