meta {
  name: List Users
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/api/users
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

settings {
  encodeUrl: true
  followRedirects: true
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("list users returns success", function() {
    const body = res.getBody();
    expect(body.status).to.equal("success");
  });
}
