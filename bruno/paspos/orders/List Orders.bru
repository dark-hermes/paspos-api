meta {
  name: "List Orders"
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/orders?store_id={{storeId}}&payment_status=paid&start_date={{startDate}}&end_date={{endDate}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

params:query {
  store_id: {{storeId}}
  payment_status: paid
  start_date: {{startDate}}
  end_date: {{endDate}}
}
